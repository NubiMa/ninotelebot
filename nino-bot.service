[Unit]
Description=Nino Telegram Bot (Long Polling)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/nino_bot
ExecStart=/usr/bin/php /var/www/nino_bot/index.php
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
